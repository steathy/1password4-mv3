# Signing key — SECRET. Losing/rotating it changes the extension ID.
build/key.pem
build/*.pem

# Build artifacts. dist/onepassword-mv3.crx and dist/extension.json ARE committed
# (they make install.ps1 one-click on any machine); the update manifest is
# generated per-machine at install time.
build/staging/
build/*.crx
build/*.reg
dist/updates.xml

# OS / editor cruft
Thumbs.db
.DS_Store
